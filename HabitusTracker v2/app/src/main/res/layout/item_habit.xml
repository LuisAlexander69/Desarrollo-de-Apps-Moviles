<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <CheckBox
            android:id="@+id/checkboxHabit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvHabitName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Nombre del Hábito"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            app:layout_constraintStart_toEndOf="@id/checkboxHabit"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvHabitStreak" />

        <TextView
            android:id="@+id/tvHabitStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvHabitCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Categoría"
            android:textSize="14sp"
            android:textColor="#757575"
            app:layout_constraintStart_toStartOf="@id/tvHabitName"
            app:layout_constraintTop_toBottomOf="@id/tvHabitName" />

        <TextView
            android:id="@+id/tvHabitFrequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Frecuencia"
            android:textSize="14sp"
            android:textColor="#757575"
            app:layout_constraintStart_toEndOf="@id/tvHabitCategory"
            app:layout_constraintBaseline_toBaselineOf="@id/tvHabitCategory" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
